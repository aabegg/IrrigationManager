      "fields": {
        "config_entry_id": {"name": "Bewässerungsanlage"},
        "zone_subentry_id": {"name": "Bewässerungszone"},
        "at": {"name": "Zeitpunkt der Gelegenheit"}
      }
    },
    "clear_forecast_deferral": {
      "name": "Prognoseaufschub abbrechen",

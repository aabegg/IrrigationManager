        "config_entry_id": {"name": "Bewässerungsanlage"},
        "zone_subentry_id": {"name": "Bewässerungszone"}
      }
    },
    "export_config": {
      "name": "Portable Konfiguration exportieren",
      "description": "Gibt die versionierte Anlagen- und Zonenkonfiguration ohne Geheimnisse zurück."
    },
    "export_history": {
      "name": "Bewässerungshistorie exportieren",
      "description": "Gibt eine begrenzte Anzahl der neuesten Bewässerungsvorgänge als JSON oder CSV zurück.",
      "fields": {
        "config_entry_id": {"name": "Bewässerungsanlage"},
        "format": {"name": "Format"},
        "limit": {"name": "Maximale Anzahl"}
      }
    },
    "resolve_balance_reconciliation": {
      "name": "Bilanzabgleich auflösen",
      "description": "Verrechnet eine nicht gutgeschriebene Lieferung mit den aktuellen Zoneneinstellungen oder verwirft sie ausdrücklich.",
      "fields": {
        "config_entry_id": {"name": "Bewässerungsanlage"},
        "reconciliation_id": {"name": "Abgleich-ID"},
        "resolution": {"name": "Auflösung"}
      }
    },
    "set_winter_lock": {"name": "Wintersperre setzen", "description": "Bestätigt die Entleerung, stoppt jede Bewässerung, schließt alle Ventile und persistiert die Wintersperre."},
    "clear_winter_lock": {"name": "Wintersperre freigeben", "description": "Gibt die Wintersperre nach einer Prüfung des geschlossenen Zustands bewusst frei."},
    "start_maintenance_test": {
      "name": "Beaufsichtigten Wartungstest starten",
      "description": "Führt genau einen zeitlich begrenzten Zonentest mit verpflichtender Dead-Man-Bestätigung aus.",
      "fields": {
        "config_entry_id": {"name": "Bewässerungsanlage"},
        "zone_subentry_id": {"name": "Bewässerungszone"},
        "duration": {"name": "Harte Testdauer"},
        "bypass_checks": {"name": "Übersteuerte Prüfungen", "description": "Nur ausgewählte implementierte Sensorprüfungen werden übersteuert. Ventilrückmeldung und Exklusivität bleiben zwingend."}
      }
    },
    "confirm_maintenance_test": {"name": "Wartungsaufsicht bestätigen", "description": "Erneuert die Dead-Man-Frist, ohne das feste Testende zu verlängern."},
    "stop_maintenance_test": {"name": "Wartungstest stoppen", "description": "Stoppt den beaufsichtigten Test und schließt alle Ventile."},
    "start_calibration": {
      "name": "Durchflusskalibrierung starten",
      "description": "Führt einen beaufsichtigten, gemessenen Zonentest aus und erzeugt einen reinen Prüfvorschlag.",
      "fields": {
        "config_entry_id": {"name": "Bewässerungsanlage"},
        "zone_subentry_id": {"name": "Bewässerungszone"},
        "duration": {"name": "Harte Testdauer"}
      }
    },
    "get_calibration_proposal": {"name": "Kalibrierungsvorschlag abrufen", "description": "Gibt den letzten Messvorschlag zurück, ohne ihn anzuwenden."},
    "resolve_calibration": {"name": "Kalibrierungsvorschlag entscheiden", "description": "Übernimmt oder verwirft einen offenen Kalibrierungsvorschlag ausdrücklich."}

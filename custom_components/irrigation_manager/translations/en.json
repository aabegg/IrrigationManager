{
  "title": "Irrigation Manager",
  "services": {
    "start_manual": {
      "name": "Start manual irrigation",
      "description": "Start one zone with exactly one duration or volume target.",
      "fields": {
        "config_entry_id": {"name": "Irrigation installation"},
        "zone_subentry_id": {"name": "Irrigation zone"},
        "duration": {"name": "Duration", "description": "Time target in seconds."},
        "amount": {"name": "Amount", "description": "Volume target in liters."},
        "hard_time_limit": {"name": "Hard time limit", "description": "Required safety timeout in seconds for a volume target."},
        "expiry": {"name": "Expiry", "description": "Maximum time in seconds before an uncompleted request expires."},
        "start_at": {"name": "Desired start", "description": "Optional one-time future start."}
      }
    },
    "create_manual": {
      "name": "Create manual irrigation request",
      "description": "Persist and queue one manual irrigation request.",
      "fields": {
        "config_entry_id": {"name": "Irrigation installation"},
        "zone_subentry_id": {"name": "Irrigation zone"},
        "duration": {"name": "Duration"},
        "amount": {"name": "Amount"},
        "hard_time_limit": {"name": "Hard time limit"},
        "expiry": {"name": "Expiry"},
        "start_at": {"name": "Desired start"}
      }
    },
    "create_manual_plan": {"name": "Create manual multi-zone plan", "description": "Atomically create an ordered set of future or immediate zone requests."},
    "edit_request": {"name": "Edit irrigation request", "description": "Edit target, desired start, or expiry before execution."},
    "reorder_requests": {"name": "Reorder irrigation requests", "description": "Set an explicit stable order for unstarted manual requests."},
    "stop_and_skip": {"name": "Stop and skip once", "description": "Stop the selected execution and suppress its current automatic opportunity."},
    "list_requests": {"name": "List irrigation requests", "description": "Return persisted manual irrigation requests."},
    "cancel_request": {"name": "Cancel irrigation request", "description": "Cancel one selected request."},
    "pause_request": {"name": "Pause irrigation request", "description": "Pause one selected request and preserve its remaining target."},
    "resume_request": {"name": "Resume irrigation request", "description": "Resume one paused request."},
    "plan_automatic": {
      "name": "Plan automatic irrigation",
      "description": "Deterministically plan the current watering opportunities, optionally without creating requests.",
      "fields": {
        "config_entry_id": {"name": "Irrigation installation"},
        "dry_run": {"name": "Dry run"},
        "at": {"name": "Planning time", "description": "Optional deterministic planning instant."}
      }
    },
    "finalize_daily_weather": {
      "name": "Finalize daily weather",
      "description": "Apply one finalized ET0 and rain period to every zone exactly once.",
      "fields": {
        "config_entry_id": {"name": "Irrigation installation"},
        "period_id": {"name": "Period ID", "description": "Stable date or accounting-period identifier."},
        "reference_evapotranspiration": {"name": "Reference evapotranspiration"},
        "rain": {"name": "Measured rain"}
      }
    },
    "skip_automatic": {
      "name": "Skip automatic watering once",
      "description": "Suppress the current watering opportunity for one zone, including across restarts.",
      "fields": {
        "config_entry_id": {"name": "Irrigation installation"},
        "zone_subentry_id": {"name": "Irrigation zone"},
        "at": {"name": "Opportunity time"}
      }
    },
    "clear_forecast_deferral": {
      "name": "Cancel forecast deferral",
      "description": "Cancel the persisted rain-forecast delay for one irrigation zone.",
      "fields": {
        "config_entry_id": {"name": "Irrigation installation"},
        "zone_subentry_id": {"name": "Irrigation zone"}
      }
    },
    "export_config": {
      "name": "Export portable configuration",
      "description": "Return the versioned installation and zone configuration without secrets."
    },
    "import_config": {"name": "Import portable configuration", "description": "Preview or explicitly overwrite this installation using a versioned export and explicit entity mappings."},
    "correct_physical_meter": {"name": "Correct physical meter", "description": "Set the observed physical meter total without rewriting historical consumption."},
    "export_history": {
      "name": "Export irrigation history",
      "description": "Return a bounded set of the newest irrigation executions as JSON or CSV.",
      "fields": {
        "config_entry_id": {"name": "Irrigation installation"},
        "format": {"name": "Format"},
        "limit": {"name": "Maximum records"}
      }
    },
    "resolve_balance_reconciliation": {
      "name": "Resolve balance reconciliation",
      "description": "Apply current zone settings to an uncredited delivery or explicitly discard it.",
      "fields": {
        "config_entry_id": {"name": "Irrigation installation"},
        "reconciliation_id": {"name": "Reconciliation ID"},
        "resolution": {"name": "Resolution"}
      }
    },
    "set_winter_lock": {"name": "Set winter lock", "description": "Confirm that the installation is drained, stop all irrigation, close all valves, and persist the winter lock."},
    "clear_winter_lock": {"name": "Clear winter lock", "description": "Consciously release the winter lock after a closed-state preflight."},
    "start_maintenance_test": {
      "name": "Start supervised maintenance test",
      "description": "Run exactly one time-bounded zone test with mandatory dead-man confirmation.",
      "fields": {
        "config_entry_id": {"name": "Irrigation installation"},
        "zone_subentry_id": {"name": "Irrigation zone"},
        "duration": {"name": "Hard test duration"},
        "bypass_checks": {"name": "Bypassed checks", "description": "Only selected implemented sensor checks are bypassed. Valve feedback and exclusivity remain mandatory."}
      }
    },
    "confirm_maintenance_test": {"name": "Confirm maintenance supervision", "description": "Refresh the dead-man deadline without extending the fixed test timeout."},
    "stop_maintenance_test": {"name": "Stop maintenance test", "description": "Stop the active supervised test and close all valves."},
    "start_calibration": {
      "name": "Start flow calibration",
      "description": "Run a supervised measured zone test and create a review-only flow proposal.",
      "fields": {
        "config_entry_id": {"name": "Irrigation installation"},
        "zone_subentry_id": {"name": "Irrigation zone"},
        "duration": {"name": "Hard test duration"}
      }
    },
    "get_calibration_proposal": {"name": "Get calibration proposal", "description": "Return the latest measured proposal without applying it."},
    "resolve_calibration": {"name": "Resolve calibration proposal", "description": "Explicitly accept or discard a pending calibration proposal."},
    "list_profiles": {"name": "List irrigation profiles", "description": "Return versioned immutable built-ins and user-owned profile copies.", "fields": {"config_entry_id": {"name": "Irrigation installation"}}},
    "preview_profile_impact": {"name": "Preview profile impact", "description": "Return every irrigation zone affected by a profile change.", "fields": {"config_entry_id": {"name": "Irrigation installation"}, "profile_id": {"name": "Profile ID"}}},
    "copy_profile": {"name": "Copy irrigation profile", "description": "Create an editable user-owned copy without modifying its built-in source.", "fields": {"config_entry_id": {"name": "Irrigation installation"}, "source_profile_id": {"name": "Source profile ID"}, "new_profile_id": {"name": "New profile ID"}, "name": {"name": "Name"}, "config_hash": {"name": "Expected profile configuration hash"}}}
  },
